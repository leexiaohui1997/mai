{
  "name": "mai-repo",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "A monorepo for MAI (My AI)",
  "author": "橙续缘",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "lint": "pnpm -r --if-present lint && eslint .",
